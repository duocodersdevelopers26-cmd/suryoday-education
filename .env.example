# ─── Suryoday Education Backend .env ───
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:   mongodb://localhost:27017/suryoday
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/suryoday
MONGODB_URI=mongodb://localhost:27017/suryoday

# Server port
PORT=5000

# Frontend URL for CORS (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:3000

# Admin key to access /api/inquiries (change this to something secret!)
ADMIN_KEY=change_this_to_a_secure_secret_key
